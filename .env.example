# ============================================
# K-12 Sentinel Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Google Workspace Configuration
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json
GOOGLE_ADMIN_EMAIL=admin@yourdistrict.org
GOOGLE_CUSTOMER_ID=my_customer

# Google OAuth (for admin login to the dashboard)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
SESSION_SECRET=change-me-to-a-random-string
ALLOWED_EMAILS=admin@yourdistrict.org
BASE_URL=https://sentinel.yourdistrict.org

# Admin Authorization (users who can access Settings page)
# Comma-separated emails and/or a Google Group
ADMIN_EMAILS=admin@yourdistrict.org
ADMIN_GROUP=sentinel-admins@yourdistrict.org

# District Email Domains (comma-separated)
# Staff domains get higher mass-send thresholds; student domains get stricter monitoring
STAFF_DOMAINS=yourdistrict.org
STUDENT_DOMAINS=students.yourdistrict.org

# District Geo-Fence (center point of your district)
DISTRICT_LAT=35.24
DISTRICT_LNG=-79.77
DISTRICT_RADIUS_MILES=100
DISTRICT_TIMEZONE=America/New_York

# Geolocation Provider: "ip-api" (free, rate limited) or "maxmind" (local DB)
GEO_PROVIDER=ip-api
MAXMIND_DB_PATH=./GeoLite2-City.mmdb

# Alert Channels (comma-separated: slack,teams,gchat,email)
ALERT_CHANNELS=gchat
ALERT_SLACK_WEBHOOK_URL=
ALERT_TEAMS_WEBHOOK_URL=
ALERT_GCHAT_WEBHOOK_URL=

# Email alerts (SMTP)
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=

# Investigation
INVESTIGATION_AUTO_THRESHOLD=60
INVESTIGATION_DEFAULT_WINDOW_HOURS=48
INVESTIGATION_MAX_CONCURRENT=3

# Server
PORT=3001
DB_PATH=./data/sentinel.db

# Traefik hostname (used in docker-compose labels)
SENTINEL_HOST=sentinel.yourdistrict.org
